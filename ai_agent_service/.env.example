# ============================================
# 🤖 AI Agent Service Environment Configuration
# ============================================
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env
#
# ⚠️ KHÔNG BAO GIỜ commit file .env vào git!
# ============================================

# --- LLM Configuration ---
# Provider: ollama | openai | groq
LLM_PROVIDER=ollama
LLM_OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_OLLAMA_MODEL=gemma4:31b-cloud

# --- Image Generation ---
# Provider: pollinations | openai
IMAGE_PROVIDER=pollinations

# --- Backend API ---
# URL của Java Backend để AI agent gọi database
BACKEND_URL=http://localhost:8080/api
